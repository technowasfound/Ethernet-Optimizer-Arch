#!/usr/bin/env python3
import os, sys, json, time, urllib.request, subprocess, configparser, socket, datetime, argparse

class Colors:
    HEADER, BLUE, CYAN, GREEN, WARNING, FAIL, ENDC, BOLD = '\033[95m', '\033[94m', '\033[96m', '\033[92m', '\033[93m', '\033[91m', '\033[0m', '\033[1m'

SYS_CONFIG_PATH = "/etc/ethoptimizer/config.conf"
BACKUP_DIR = "/var/lib/ethoptimizer/backups"
LOG_DIR = "/var/log/ethoptimizer"
SYSCTL_CONF_DEST = "/etc/sysctl.d/99-ethoptimizer.conf"

class ConfigManager:
    @staticmethod
    def ensure_dirs():
        for p in [os.path.dirname(SYS_CONFIG_PATH), BACKUP_DIR, LOG_DIR]:
            os.makedirs(p, exist_ok=True) if not os.path.exists(p) else None

    @staticmethod
    def load_config():
        config = configparser.ConfigParser()
        if os.path.exists(SYS_CONFIG_PATH):
            config.read(SYS_CONFIG_PATH)
        else:
            config['general'] = {'log_file': os.path.join(LOG_DIR, 'ethoptimizer.log')}
            config['speedtest'] = {
                'ping_hosts': '1.1.1.1, 8.8.8.8',
                'download_urls': 'https://speed.cloudflare.com/__down?bytes=10485760',
                'upload_endpoint': 'https://httpbin.org/post'
            }
            config['profile_gaming'] = {
                'net.ipv4.tcp_congestion_control': 'bbr', 'net.ipv4.tcp_fastopen': '3',
                'net.ipv4.tcp_low_latency': '1', 'net.ipv4.tcp_timestamps': '0', 'net.ipv4.tcp_sack': '1',
                'net.core.rmem_max': '16777216', 'net.core.wmem_max': '16777216',
                'net.core.default_qdisc': 'fq', 'ethtool_coalesce': 'rx-usecs 10 tx-usecs 10'
            }
        return config

    @staticmethod
    def backup_state(dry_run=False):
        if dry_run: return "dry-run-backup"
        ConfigManager.ensure_dirs()
        backup_file = os.path.join(BACKUP_DIR, f"backup_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.json")
        sysctl_vars = ["net.ipv4.tcp_congestion_control", "net.ipv4.tcp_fastopen", "net.core.rmem_max", "net.core.wmem_max", "net.core.default_qdisc"]
        backup_data = {"sysctl": {}, "timestamp": str(datetime.datetime.now())}
        for v in sysctl_vars:
            res = subprocess.run(["sysctl", "-n", v], capture_output=True, text=True)
            if res.returncode == 0: backup_data["sysctl"][v] = res.stdout.strip()
        with open(backup_file, "w") as f: json.dump(backup_data, f, indent=4)
        return backup_file

class SpeedTester:
    @staticmethod
    def run_ping_test(hosts):
        results = []
        for host in hosts:
            print(f" -> Pinging {host}...")
            try:
                proc = subprocess.run(["ping", "-c", "4", "-W", "2", host], capture_output=True, text=True, timeout=10)
                if proc.returncode != 0: continue
                latencies = [float(line.split("time=")[1].split(" ")[0]) for line in proc.stdout.splitlines() if "time=" in line]
                if latencies:
                    avg_rtt = sum(latencies) / len(latencies)
                    diffs = [abs(latencies[i] - latencies[i-1]) for i in range(1, len(latencies))]
                    results.append({"host": host, "avg": avg_rtt, "jitter": sum(diffs)/len(diffs) if diffs else 0.0})
            except Exception: pass
        return results

    @staticmethod
    def run_download_test(urls):
        print(" -> Running Download Speed Test...")
        results = []
        for url in urls:
            try:
                start = time.time()
                req = urllib.request.urlopen(urllib.request.Request(url, headers={'User-Agent': 'Mozilla'}), timeout=10)
                bytes_dl = len(req.read())
                duration = time.time() - start
                mbps = (bytes_dl * 8) / (1024 * 1024 * duration)
                print(f"    {Colors.GREEN}[✔] Completed: {mbps:.2f} Mbps ({duration:.2f}s){Colors.ENDC}")
                results.append({"url": url, "mbps": mbps})
            except Exception as e:
                print(f"    {Colors.FAIL}[!] Failed: {e}{Colors.ENDC}")
        return results

class DiagnosticEngine:
    @staticmethod
    def get_interface():
        res = subprocess.run(["ip", "route", "show", "default"], capture_output=True, text=True)
        parts = res.stdout.split()
        return parts[parts.index("dev") + 1] if "dev" in parts else "eth0"

    @staticmethod
    def run_diagnostics(iface):
        diag = {"interface": iface}
        try:
            with open(f"/sys/class/net/{iface}/mtu") as f: diag["mtu"] = f.read().strip()
        except: diag["mtu"] = "Unknown"
        res = subprocess.run(["sysctl", "-n", "net.ipv4.tcp_congestion_control"], capture_output=True, text=True)
        diag["cc"] = res.stdout.strip()
        return diag

class Optimizer:
    @staticmethod
    def apply_profile(profile, config, dry_run=False):
        sec = f"profile_{profile}"
        if not config.has_section(sec): return print(f"{Colors.FAIL}[!] Profile {profile} missing{Colors.ENDC}")
        if not dry_run and os.getuid() != 0: return print(f"{Colors.FAIL}[!] Root (sudo) required{Colors.ENDC}")
        
        backup = ConfigManager.backup_state(dry_run)
        print(f"{Colors.BLUE}[*] State Backed Up to: {backup}{Colors.ENDC}")
        sysctls, ethtools = {}, []
        for k, v in config.items(sec):
            sysctls[k] = v if k.startswith("net.") or k.startswith("fs.") else None
            ethtools.append((k, v)) if k.startswith("ethtool_") else None

        if sysctls and not dry_run:
            with open(SYSCTL_CONF_DEST, "w") as f:
                for k, v in sysctls.items():
                    if v: f.write(f"{k} = {v}\n"); subprocess.run(["sysctl", "-w", f"{k}={v}"], capture_output=True)
            print(f"{Colors.GREEN}[✔] Kernel flags set successfully.{Colors.ENDC}")
        return True

    @staticmethod
    def revert():
        if os.getuid() != 0: return print(f"{Colors.FAIL}[!] Root required{Colors.ENDC}")
        backups = sorted([f for f in os.listdir(BACKUP_DIR) if f.startswith("backup_")]) if os.path.exists(BACKUP_DIR) else []
        if not backups: return print(f"{Colors.WARNING}[!] No backups found{Colors.ENDC}")
        with open(os.path.join(BACKUP_DIR, backups[-1])) as f:
            data = json.load(f)
            for k, v in data.get("sysctl", {}).items():
                subprocess.run(["sysctl", "-w", f"{k}={v}"], capture_output=True)
        if os.path.exists(SYSCTL_CONF_DEST): os.remove(SYSCTL_CONF_DEST)
        print(f"{Colors.GREEN}[✔] Settings reverted successfully.{Colors.ENDC}")

def main():
    parser = argparse.ArgumentParser(description="ethoptimizer: Arch Linux Network Tuner")
    parser.add_argument("command", choices=["speed-test", "diagnose", "optimize", "revert"])
    parser.add_argument("--profile", default="gaming")
    parser.add_argument("--dry-run", action="store_true")
    args = parser.parse_args()
    
    config = ConfigManager.load_config()
    iface = DiagnosticEngine.get_interface()

    if args.command == "diagnose":
        d = DiagnosticEngine.run_diagnostics(iface)
        print(f"Interface: {d['interface']} | MTU: {d['mtu']} | Congestion Engine: {d['cc']}")
    elif args.command == "speed-test":
        SpeedTester.run_ping_test([h.strip() for h in config.get('speedtest', 'ping_hosts').split(',')])
        SpeedTester.run_download_test([u.strip() for u in config.get('speedtest', 'download_urls').split(',')])
    elif args.command == "optimize":
        Optimizer.apply_profile(args.profile, config, args.dry_run)
    elif args.command == "revert":
        Optimizer.revert()

if __name__ == "__main__":
    main()
